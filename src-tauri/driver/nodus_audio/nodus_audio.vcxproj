<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{CF8D6B2A-F0E1-4A3C-8D9B-12345678ABCD}</ProjectGuid>
    <RootNamespace>nodus_audio</RootNamespace>
    <Configuration Condition="'$(Configuration)'==''">Release</Configuration>
    <Platform Condition="'$(Platform)'==''">x64</Platform>
    <!-- WindowsTargetPlatformVersion is passed by CI (/p:) to match the EWDK kit;
         if unset, Microsoft.Cpp.Default.props falls back to the latest installed. -->
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Label="Configuration">
    <ConfigurationType>Driver</ConfigurationType>
    <DriverType>WDM</DriverType>
    <DriverTargetPlatform>Universal</DriverTargetPlatform>
    <TargetVersion>Windows10</TargetVersion>
    <PlatformToolset>WindowsKernelModeDriver10.0</PlatformToolset>
    <!-- Avoid requiring Spectre-mitigated runtime libs that may be absent in CI. -->
    <SpectreMitigation>false</SpectreMitigation>
    <!-- Don't sign during the build — CI signs the .sys/.cat separately with a test cert. -->
    <SignMode>Off</SignMode>
    <!-- Skip the in-build Inf2Cat/catalog step: it runs with empty Configuration/Platform
         and packages only the .inf (not the .sys), so inf2cat fails. CI generates and
         signs the catalog separately in the Test-sign step. -->
    <EnableInf2Cat>false</EnableInf2Cat>
    <UseDebugLibraries Condition="'$(Configuration)'=='Debug'">true</UseDebugLibraries>
    <UseDebugLibraries Condition="'$(Configuration)'=='Release'">false</UseDebugLibraries>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <PropertyGroup>
    <TargetName>nodus_audio</TargetName>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <!-- PortCls requires C++ exceptions and RTTI disabled in kernel mode. -->
      <ExceptionHandling>false</ExceptionHandling>
      <RuntimeTypeInfo>false</RuntimeTypeInfo>
      <!-- The kernel toolset already defines _KERNEL_MODE (redefining = C4117), so we
           do not add it here. stdunk.h emits a deprecation warning (operator new/delete)
           that has no warning code to suppress, so don't treat warnings as errors for
           this MVP driver build. -->
      <TreatWarningAsError>false</TreatWarningAsError>
    </ClCompile>
    <Link>
      <!-- Audio kernel libraries. stdunk.lib provides the CUnknown base-class
           implementation (constructor/destructor + NonDelegating* methods). -->
      <AdditionalDependencies>portcls.lib;stdunk.lib;ks.lib;ksguid.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
    <Inf>
      <SpecifyArchitecture>true</SpecifyArchitecture>
      <SpecifyDriverVerDirectiveVersion>true</SpecifyDriverVerDirectiveVersion>
    </Inf>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="adapter.cpp" />
    <ClCompile Include="miniport.cpp" />
    <ClCompile Include="stream.cpp" />
  </ItemGroup>

  <ItemGroup>
    <ClInclude Include="common.h" />
    <ClInclude Include="miniport.h" />
    <ClInclude Include="stream.h" />
  </ItemGroup>

  <ItemGroup>
    <Inf Include="nodus_audio.inf" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />

</Project>
