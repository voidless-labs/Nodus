{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Nodus",
    "version": "0.5.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "window": {
        "all": false,
        "minimize": true,
        "unminimize": true,
        "maximize": true,
        "unmaximize": true,
        "close": true,
        "hide": true,
        "show": true,
        "setFocus": true,
        "startDragging": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.nodus.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "systemTray": {
      "iconPath": "icons/tray.ico",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "decorations": false,
        "title": "Nodus",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "fileDropEnabled": false
      },
      {
        "label": "quick",
        "url": "index.html?w=quick",
        "title": "Nodus Quick Controls",
        "width": 360,
        "height": 612,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false,
        "focus": false,
        "fileDropEnabled": false
      }
    ]
  }
}
